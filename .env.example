# PrivateTunes — Environment Configuration
# Copy this file to .env and update with your values
# Example: cp .env.example .env

# Your domain name (e.g., yourdomain.duckdns.org)
# Used by Caddy for automatic HTTPS certificate provisioning
DOMAIN=your-domain.duckdns.org

# User/Group IDs for Syncthing file ownership (defaults to 1000)
UID=1000
GID=1000
