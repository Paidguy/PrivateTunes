# PrivateTunes — Environment Configuration
# Copy this file to .env and update with your values
# Example: cp .env.example .env

# Your domain name (e.g., yourdomain.duckdns.org)
# Used by Caddy for automatic HTTPS certificate provisioning
# Leave as-is to skip HTTPS and use http://localhost:4533 instead
DOMAIN=your-domain.duckdns.org

# User/Group IDs for Syncthing file ownership
# Run `id -u` and `id -g` to find your values (usually 1000)
UID=1000
GID=1000
